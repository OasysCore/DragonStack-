}

# List all skills
list_skills() {
    show_banner
    echo -e "${GREEN}Core Skills (6) / 核心技能:${NC}"
    echo "  ✓ brainstorm    - Product ideation / 产品构思"
    echo "  ✓ design        - Architecture design / 架构设计"
    echo "  ✓ code          - Code generation / 代码生成"
