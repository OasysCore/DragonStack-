# Execute skill with MAWA governance
execute_skill() {
    local skill_name="$1"
    shift
    local args="$@"
    
    # Ensure MAWA is initialized
    if [ "$MAWA_ENABLED" = true ]; then
        ensure_mawa_dirs
        
        # Start TaskRun
        local taskrun_id=$(start_taskrun "${skill_name}_execution" "$skill_name" "./dragonstack ${skill_name} ${args}")
        
        echo -e "${BLUE}📋 TaskRun ID: ${taskrun_id}${NC}"
        
        # Log skill invocation
        log_taskrun_step "$taskrun_id" "skill_invocation" "skill" "executing_${skill_name}"
        
        # Record start time
        local start_time=$(date +%s%N | cut -b1-13)
    fi
    
    # Execute the skill
    local skill_script="$SCRIPT_DIR/skills/${skill_name}/${skill_name}.sh"
    if [ -f "$skill_script" ]; then
        "$skill_script" $args
        local exit_code=$?
    else
        # Try alternative naming
        skill_script="$SCRIPT_DIR/skills/${skill_name}/${skill_name}.sh"
        if [ -f "$skill_script" ]; then
            "$skill_script" $args
            local exit_code=$?
        else
            echo -e "${RED}❌ Skill not found: ${skill_name}${NC}"
            return 1
        fi
    fi
    
    # Complete TaskRun
    if [ "$MAWA_ENABLED" = true ] && [ -n "$taskrun_id" ]; then
        local end_time=$(date +%s%N | cut -b1-13)
        local duration_ms=$((end_time - start_time))
        
        local status="failed"
        if [ $exit_code -eq 0 ]; then
            status="success"
        fi
        
        complete_taskrun "$taskrun_id" "$status" "exit_code_${exit_code}" "$duration_ms"
        
        echo -e "${BLUE}📊 Execution recorded: ${duration_ms}ms${NC}"
    fi
    
    return $exit_code
}

# Handle natural language input
handle_natural_language() {
    local input="$1"
    
    if [ "$MAWA_ENABLED" != true ]; then
        echo -e "${RED}❌ MAWA not enabled. Cannot process natural language.${NC}"
        return 1
    fi
    
    ensure_mawa_dirs
    
    echo -e "${CYAN}🧠 Processing natural language input...${NC}"
    echo -e "${YELLOW}   Input: ${input}${NC}"
    echo ""
    
    # Start TaskRun
    local taskrun_id=$(start_taskrun "natural_language_dispatch" "dispatcher" "${input}")
    
    # Dispatch to appropriate skill
    local suggested_skill=$(dispatch_task "$input" "$taskrun_id")
    
    echo ""
    echo -e "${GREEN}🎯 Dispatching to skill: ${suggested_skill}${NC}"
    echo ""
    
    # Ask for confirmation
    read -p "Execute this skill? [Y/n]: " confirm
    if [[ "$confirm" =~ ^[Nn]$ ]]; then
        echo -e "${YELLOW}Cancelled.${NC}"
        complete_taskrun "$taskrun_id" "cancelled" "user_cancelled" "0"
        return 0
    fi
    
    # Execute the skill
    log_taskrun_step "$taskrun_id" "user_confirmation" "decision" "confirmed"
    
    echo ""
    execute_skill "$suggested_skill"
    
    return $?
}

# Main logic
main() {
    # Ensure MAWA directories exist
    if [ "$MAWA_ENABLED" = true ]; then
        ensure_mawa_dirs
    fi
    
    # No arguments - show menu
    if [ $# -eq 0 ]; then
        show_banner
        echo "Available skills / 可用技能:"
        echo ""
        echo "  1) brainstorm   - Product ideation"
        echo "  2) design       - Architecture design"
        echo "  3) code         - Code generation"
        echo "  4) code-review  - Code review"
        echo "  5) test         - Test planning"
        echo "  6) ship         - Release"
        echo "  7) debug        - Debugging"
        echo "  8) doc          - Documentation"
        echo "  9) refactor     - Refactoring"
        echo ""
        echo "Or use natural language:"
        echo "  ./dragonstack --natural 'your request here'"
        echo ""
        echo "Run './dragonstack help' for more info"
        echo "运行 './dragonstack help' 获取更多信息"
        exit 0
    fi
    
    # Check for natural language mode
    if [ "$1" = "--natural" ] || [ "$1" = "-n" ]; then
        shift
        local nl_input="$*"
        handle_natural_language "$nl_input"
        exit $?
    fi
    
    # Parse command
    COMMAND="$1"
    shift
    
    case "$COMMAND" in
        help|--help|-h)
            show_help
            ;;
        version|--version|-v)
            show_version
            ;;
        list|--list|-l)
            list_skills
            ;;
        mawa-status|mawa-status)
            if [ "$MAWA_ENABLED" = true ]; then
                mawa_status
            else
                echo -e "${RED}❌ MAWA not enabled.${NC}"
                exit 1
            fi
            ;;
        mawa-inspect)
            if [ "$MAWA_ENABLED" = true ]; then
                if [ -z "$1" ]; then
                    echo -e "${RED}❌ Usage: ./dragonstack mawa-inspect <skill-name>${NC}"
                    exit 1
                fi
                mawa_inspect_skill "$1"
            else
                echo -e "${RED}❌ MAWA not enabled.${NC}"
                exit 1
            fi
            ;;
        taskruns|taskrun|runs)
            if [ "$MAWA_ENABLED" = true ]; then
                ensure_mawa_dirs
                echo -e "${CYAN}📋 Recent TaskRuns:${NC}"
                get_recent_taskruns "${1:-10}" | sed 's/^/  /'
            else
                echo -e "${RED}❌ MAWA not enabled.${NC}"
                exit 1
            fi
            ;;
        brainstorm)
            execute_skill "brainstorm" "$@"
            ;;
        design)
            execute_skill "design" "$@"
            ;;
        code)
            execute_skill "code" "$@"
            ;;
        code-review|review)
            execute_skill "code-review" "$@"
            ;;
        test)
            execute_skill "test" "$@"
            ;;
        ship)
            execute_skill "ship" "$@"
            ;;
        debug)
            execute_skill "debug" "$@"
            ;;
        doc|docs)
            execute_skill "doc" "$@"
            ;;
        refactor)
            execute_skill "refactor" "$@"
            ;;
        *)
            # Try natural language dispatch for unknown commands
            if [ "$MAWA_ENABLED" = true ]; then
                echo -e "${YELLOW}⚠️  Unknown command. Trying natural language dispatch...${NC}"
                echo ""
                handle_natural_language "$COMMAND $*"
            else
                echo -e "${RED}❌ Unknown skill: $COMMAND${NC}"
                echo ""
                echo "Run './dragonstack help' for available skills"
                echo "运行 './dragonstack help' 查看可用技能"
                exit 1
            fi
            ;;
    esac
}

# Run main
main "$@"
